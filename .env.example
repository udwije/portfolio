# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# Contact form endpoint (if you add a backend)
# CONTACT_API_ENDPOINT=https://api.mercersecurity.com/contact

# No sensitive secrets should be prefixed with NEXT_PUBLIC_
# Those are exposed to the browser
